{
  "name": "@diff-review-system/drs",
  "version": "4.0.0",
  "description": "Workflow-first AI code maintenance for reviews, changelogs, docs, and repository upkeep.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "drs": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx watch src/cli/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:temporal:smoke": "DRS_TEMPORAL_SMOKE=1 vitest run src/temporal/smoke.test.ts",
    "test:e2e": "DRS_E2E_LIVE=1 vitest run src/cli/review-local.live.e2e.test.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,json}' 'package.json' '.pi/**/*.{yaml,yml}'",
    "format:check": "prettier --check 'src/**/*.{ts,json}' 'package.json' '.pi/**/*.{yaml,yml}'",
    "check:all": "npm run format && npm run lint:fix && npm run build && npm test && npm run format:check && npm run lint && npm run desktop:check",
    "desktop:check": "npm --prefix desktop run typecheck && npm --prefix desktop run build",
    "type-check": "tsc --noEmit",
    "prek:install": "prek install",
    "prek:run": "prek run --all-files",
    "prek:uninstall": "prek uninstall",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE",
    ".pi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojlds/drs.git"
  },
  "bugs": {
    "url": "https://github.com/manojlds/drs/issues"
  },
  "homepage": "https://github.com/manojlds/drs#readme",
  "keywords": [
    "gitlab",
    "github",
    "code-review",
    "pi",
    "diff-review",
    "merge-request",
    "pull-request",
    "code-analysis",
    "static-analysis"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.6",
    "@gitbeaker/node": "^35.8.1",
    "@octokit/rest": "^21.0.0",
    "@sinclair/typebox": "^0.34.49",
    "@temporalio/activity": "^1.18.1",
    "@temporalio/client": "^1.18.1",
    "@temporalio/worker": "^1.18.1",
    "@temporalio/workflow": "^1.18.1",
    "ajv": "^8.20.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0",
    "simple-git": "^3.36.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
