{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DRS Project Configuration",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "workflow": {
      "title": "Workflow Defaults",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "default": {
          "title": "Default workflow",
          "type": "string"
        }
      }
    },
    "agents": {
      "title": "Agents",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "paths": {
          "title": "Custom paths",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "agents": {
              "title": "Agents path",
              "type": "string"
            },
            "skills": {
              "title": "Skills path",
              "type": "string"
            }
          }
        },
        "default": {
          "$ref": "#/$defs/agentDefaults",
          "title": "Default agent settings"
        },
        "namespaces": {
          "title": "Namespace defaults",
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/agentDefaults" }
        },
        "overrides": {
          "title": "Agent overrides",
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/agentDefaults" }
        }
      }
    },
    "review": {
      "title": "Review Behavior",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "agents": {
          "title": "Review agents",
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "model": { "type": "string" },
                  "skills": { "type": "array", "items": { "type": "string" } }
                }
              }
            ]
          }
        },
        "ignorePatterns": {
          "title": "Ignore patterns",
          "type": "array",
          "items": { "type": "string" }
        },
        "includePatterns": {
          "title": "Include patterns",
          "type": "array",
          "items": { "type": "string" }
        },
        "unified": {
          "title": "Unified reviewer",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "model": { "title": "Model", "type": "string" }
          }
        },
        "describe": {
          "title": "Review descriptions",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "title": "Enabled", "type": "boolean" }
          }
        },
        "cursorFixLinks": {
          "title": "Cursor fix links",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "title": "Enabled", "type": "boolean" },
            "workspace": { "title": "Workspace", "type": "string" }
          }
        },
        "skipRepoCheck": { "title": "Skip repository check", "type": "boolean" },
        "skipBranchCheck": { "title": "Skip branch check", "type": "boolean" }
      }
    },
    "describe": {
      "title": "Describe",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model": { "title": "Model", "type": "string" },
        "includeProjectContext": { "title": "Include project context", "type": "boolean" }
      }
    },
    "contextCompression": {
      "title": "Context Compression",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxTokens": { "type": "number" },
        "thresholdPercent": { "type": "number" },
        "softBufferTokens": { "type": "number" },
        "hardBufferTokens": { "type": "number" },
        "tokenEstimateDivisor": { "type": "number" },
        "summaryThresholdMultiplier": { "type": "number" }
      }
    },
    "github": {
      "title": "GitHub",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "token": { "title": "Token", "type": "string" }
      }
    },
    "gitlab": {
      "title": "GitLab",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "url": { "title": "URL", "type": "string" },
        "token": { "title": "Token", "type": "string" }
      }
    },
    "temporal": {
      "title": "Temporal",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "address": { "type": "string" },
        "namespace": { "type": "string" },
        "taskQueue": { "type": "string" },
        "workflowIdPrefix": { "type": "string" },
        "workspace": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": { "type": "string", "enum": ["local", "managed"] },
            "root": { "type": "string" }
          }
        }
      }
    },
    "pi": {
      "title": "Pi Runtime",
      "type": "object",
      "additionalProperties": true
    },
    "pricing": {
      "title": "Pricing",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "models": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/modelPricing" }
        }
      }
    },
    "fix": {
      "title": "Fix Pipeline",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "command"],
            "properties": {
              "name": { "type": "string" },
              "command": { "type": "string" },
              "matchPaths": { "type": "array", "items": { "type": "string" } },
              "timeoutMs": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "agentDefaults": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model": { "title": "Model", "type": "string" },
        "skills": { "title": "Skills", "type": "array", "items": { "type": "string" } },
        "skillsPromptFormat": {
          "title": "Skills prompt format",
          "type": "string",
          "enum": ["text", "xml"]
        },
        "thinkingLevel": { "title": "Thinking level", "type": "string" },
        "tools": {
          "title": "Tools",
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "run": {
          "title": "Run defaults",
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "prompt": { "type": "string" },
            "promptFile": { "type": "string" },
            "output": { "type": "string" },
            "json": { "type": "boolean" }
          }
        }
      }
    },
    "modelPricing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": { "type": "number" },
        "output": { "type": "number" },
        "cacheRead": { "type": "number" },
        "cacheWrite": { "type": "number" }
      }
    }
  }
}
